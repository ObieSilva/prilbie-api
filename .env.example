# ─── Database (Neon) ──────────────────────────────────────
# Loaded by Nest (ConfigModule) and Prisma CLI via prisma.config.ts + src/config/root-env-path.ts
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/consistency_app?sslmode=require

# ─── Cache (Upstash Redis) ───────────────────────────────
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=AXxx...

# ─── Clerk Auth ───────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY=...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── AI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o

# ─── App ──────────────────────────────────────────────────
# Local: 3001 keeps port 3000 free for other tools. Cloud Run sets PORT (e.g. 8080) — no need to duplicate in secrets if the platform injects it.
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
USE_NEON=false
