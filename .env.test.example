# Copy to `.env.test` (gitignored) and set a dedicated test database URL.
# Never use production credentials here.
#
# Loaded by `test/setup.ts` and `test/helpers/test-app.ts` before e2e runs.
# Nest `ConfigModule` still reads repo-root `.env` unless vars are already set —
# e2e loads this file first so `DATABASE_URL` / `USE_NEON` apply to Prisma and the app.

NODE_ENV=test

# Separate Postgres (Neon branch or local), not your dev DB
DATABASE_URL=postgresql://user:pass@localhost:5432/consistency_app_test?sslmode=require

# Match connection style to DATABASE_URL (same as PrismaService)
USE_NEON=false

# Required shape for `validateEnv` when NODE_ENV is not production — placeholders are fine
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_JWT_KEY=placeholder-public-key
OPENAI_API_KEY=sk-placeholder

PORT=3001
CORS_ORIGINS=http://localhost:3000

# Optional (e2e skips real Redis if unset — verify CacheModule behavior)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# E2e resets data with `npx prisma db execute --stdin` (see test/helpers/truncate-app-tables.ts).
# The child process inherits DATABASE_URL from this file (loaded before tests).
