{
  "globalSetup": "<rootDir>/global-setup-e2e.js",
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFilesAfterEnv": [
    "<rootDir>/setup.ts",
    "<rootDir>/setup-e2e-clerk.ts"
  ],
  "maxWorkers": 1,
  "testTimeout": 120000,
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json"
      }
    ]
  }
}